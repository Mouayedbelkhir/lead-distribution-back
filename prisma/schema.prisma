// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vertical {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  deliveries Delivery[]
  leads     Lead[]
}

model Client {
  id          Int        @id @default(autoincrement())
  name        String
  deliveries  Delivery[]
}

model Delivery {
  id          Int      @id @default(autoincrement())
  clientId    Int
  verticalId  Int

  minAge      Int
  maxAge      Int
  capacity    Int
  price       Float

  client      Client   @relation(fields: [clientId], references: [id])
  vertical    Vertical @relation(fields: [verticalId], references: [id])

  leads       Lead[]
}

model Lead {
  id                   Int       @id @default(autoincrement())
  firstName            String
  lastName             String
  birthDate            DateTime
  postalCode           String

  verticalId           Int
  assignedDeliveryId   Int?

  vertical             Vertical  @relation(fields: [verticalId], references: [id])
  assignedDelivery     Delivery? @relation(fields: [assignedDeliveryId], references: [id])
}